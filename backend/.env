# Server
PORT=3200
NODE_ENV=development

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neutara_deployment
DB_USER=postgres
DB_PASSWORD=Bharath1708

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760     # 10 MB in bytes

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# Email (SMTP) — for multi-project scope emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@neutara.com
SCOPE_EMAIL_RECIPIENT=admin@neutara.com