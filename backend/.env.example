# Server
PORT=5000
NODE_ENV=development

# SQL Server connection
DB_HOST=localhost          # For named instance use: localhost\SQLEXPRESS
DB_PORT=1433               # Leave blank if using a named instance (e.g. SQLEXPRESS)
DB_NAME=neutara_deployment
DB_USER=sa                 # SQL Server login (or leave blank for Windows Auth)
DB_PASSWORD=YourPassword!  # SA password or a dedicated login
DB_ENCRYPT=false           # true if using Azure SQL / SSL
DB_TRUST_CERT=true         # true for local/dev; false in production
DB_INSTANCE=               # Named instance override e.g. SQLEXPRESS (optional)

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760     # 10 MB in bytes

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
