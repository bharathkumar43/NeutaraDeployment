# Server
PORT=3200
NODE_ENV=production

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neutara_deployment
DB_USER=postgres
DB_PASSWORD=changeme

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# Azure AD (Microsoft Entra ID)
# Get these from Azure Portal → App Registrations → your app → Overview
AZURE_TENANT_ID=your_azure_directory_tenant_id
AZURE_CLIENT_ID=your_azure_application_client_id

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3201

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Microsoft Graph API — for all email notifications
# App registration must have Mail.Send Application permission (admin consent granted)
AZURE_CLIENT_SECRET=your_azure_client_secret_here
EMAIL_SENDER=sender@yourdomain.com

# QA submission emails — up to 3 DLs receive the notification simultaneously
EMAIL_QA_DL=qa-team@yourdomain.com
EMAIL_QA_DL_2=
EMAIL_QA_DL_3=

# Infra team DL — notified when QA approves (ready for deployment)
EMAIL_INFRA_DL=infra-team@yourdomain.com

# Deployment completion emails
# EMAIL_DEPLOYMENT_DL — receives FYI on every deployment success/failure
# EMAIL_ACK_NOTIFY_DL — additional DL that gets the FYI acknowledgement email (no action button)
EMAIL_DEPLOYMENT_DL=deployment-dl@yourdomain.com
EMAIL_ACK_NOTIFY_DL=

SCOPE_EMAIL_RECIPIENT=scope-dl@yourdomain.com
APP_URL=http://localhost:3201
