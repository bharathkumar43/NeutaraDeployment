# Server
PORT=3200
NODE_ENV=production

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neutara_deployment
DB_USER=postgres
DB_PASSWORD=changeme

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3201

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Email (SMTP) — for multi-project scope emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@neutara.com
SCOPE_EMAIL_RECIPIENT=
