# ── App URL ────────────────────────────────────────────────────
# Full public URL (no trailing slash). Used for CORS and redirects.
APP_URL=https://depreq.cftools.live

# ── Security ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_string

# ── Database ───────────────────────────────────────────────────
DB_PASSWORD=replace_with_a_strong_password

# ── Azure AD (Microsoft Entra ID) ──────────────────────────────
# Backend — used server-side to exchange auth codes for tokens
AZURE_TENANT_ID=66d8848d-26b6-4147-8124-127624d7b3a6
AZURE_CLIENT_ID=861e696d-f41c-41ee-a7c2-c838fd185d6d
AZURE_CLIENT_SECRET=your_client_secret_here

# Frontend — baked into the JS bundle at Docker build time by Vite
# MUST match the Azure values above — docker-compose passes these as build args
VITE_AZURE_CLIENT_ID=861e696d-f41c-41ee-a7c2-c838fd185d6d
VITE_AZURE_TENANT_ID=66d8848d-26b6-4147-8124-127624d7b3a6

# ── Email (Microsoft Graph API) ────────────────────────────────
# App registration must have Mail.Send Application permission (admin consent granted)
EMAIL_SENDER=sender@yourdomain.com
EMAIL_QA_DL=qa-team@yourdomain.com
EMAIL_INFRA_DL=infra-team@yourdomain.com
SCOPE_EMAIL_RECIPIENT=scope-dl@yourdomain.com
